# ═══════════════════════════════════════════════════════════════
# Gloss Ecosystem - Staging Environment Template
# Copy to .env.staging and fill in values
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# DATABASE (Staging - Separate from Production)
# ═══════════════════════════════════════════════════════════════
POSTGRES_USER=gloss_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=gloss_staging

# ═══════════════════════════════════════════════════════════════
# REDIS (Staging)
# ═══════════════════════════════════════════════════════════════
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD

# ═══════════════════════════════════════════════════════════════
# MINIO / S3 (Staging)
# ═══════════════════════════════════════════════════════════════
MINIO_ROOT_USER=gloss_minio_staging
MINIO_ROOT_PASSWORD=CHANGE_ME_STAGING_MINIO_PASSWORD
MINIO_BUCKET=gloss-staging-uploads

# ═══════════════════════════════════════════════════════════════
# JWT & AUTH (Staging - Different from Production!)
# ═══════════════════════════════════════════════════════════════
JWT_ACCESS_SECRET=CHANGE_ME_STAGING_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_STAGING_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ═══════════════════════════════════════════════════════════════
# YANDEX MAPS (Staging - Use Staging API Keys)
# ═══════════════════════════════════════════════════════════════
YANDEX_MAPKIT_API_KEY=STAGING_YANDEX_API_KEY

# ═══════════════════════════════════════════════════════════════
# FIREBASE / FCM (Staging Project)
# ═══════════════════════════════════════════════════════════════
FCM_SERVER_KEY=STAGING_FCM_SERVER_KEY
FCM_PROJECT_ID=gloss-staging-xxx

# ═══════════════════════════════════════════════════════════════
# PAYMENTS - CLICK (Staging/Test Credentials)
# ═══════════════════════════════════════════════════════════════
CLICK_MERCHANT_ID=STAGING_CLICK_MERCHANT_ID
CLICK_SECRET_KEY=STAGING_CLICK_SECRET_KEY
CLICK_SERVICE_ID=STAGING_CLICK_SERVICE_ID

# ═══════════════════════════════════════════════════════════════
# PAYMENTS - PAYME (Staging/Test Credentials)
# ═══════════════════════════════════════════════════════════════
PAYME_MERCHANT_ID=STAGING_PAYME_MERCHANT_ID
PAYME_SECRET_KEY=STAGING_PAYME_SECRET_KEY
PAYME_TEST_MODE=true

# ═══════════════════════════════════════════════════════════════
# SMS PROVIDER (Eskiz - Staging)
# ═══════════════════════════════════════════════════════════════
SMS_PROVIDER=eskiz
SMS_API_KEY=STAGING_ESKIZ_API_KEY
SMS_SENDER_ID=GLOSS-STG

# ═══════════════════════════════════════════════════════════════
# BACKEND CONFIG
# ═══════════════════════════════════════════════════════════════
NODE_ENV=staging
API_PORT=3000
CORS_ORIGINS=https://staging.gloss.uz,https://staging-client.gloss.uz,https://staging-provider.gloss.uz,https://staging-seller.gloss.uz
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════
# FRONTEND URLS (Staging)
# ═══════════════════════════════════════════════════════════════
CLIENT_APP_URL=https://staging-client.gloss.uz
PROVIDER_APP_URL=https://staging-provider.gloss.uz
SELLER_APP_URL=https://staging-seller.gloss.uz
ADMIN_APP_URL=https://staging-admin.gloss.uz

# ═══════════════════════════════════════════════════════════════
# SENTRY (Staging DSN)
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN=https://STAGING_SENTRY_DSN@sentry.io/PROJECT_ID

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS (Staging)
# ═══════════════════════════════════════════════════════════════
FEATURE_FLAG_NEW_CHECKOUT=true
FEATURE_FLAG_CHAT_V2=true
FEATURE_FLAG_ANALYTICS_V2=false