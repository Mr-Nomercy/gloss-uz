# ── Database ──
DATABASE_URL=postgresql://postgres:gloss_secret@localhost:5432/gloss_dev?pgbouncer=true&connection_limit=20&pool_timeout=10

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── MinIO ──
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=gloss_minio
MINIO_SECRET_KEY=gloss_minio_secret
MINIO_BUCKET=gloss-uploads

# ── JWT ──
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Yandex MapKit ──
YANDEX_MAPKIT_API_KEY=dev-key

# ── Firebase ──
FCM_SERVER_KEY=
FCM_PROJECT_ID=gloss-dev-xxx

# ── Click ──
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

# ── Payme ──
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# ── SMS ──
SMS_PROVIDER=eskiz
SMS_API_KEY=

# ── Logging ──
LOG_LEVEL=debug
NODE_ENV=development

# ── Backend ──
API_PORT=3000
CORS_ORIGINS=http://localhost:3000,https://gloss-client.uz
