# ═══════════════════════════════════════════════════════════════
# Gloss Ecosystem - Production Environment Template
# Copy to .env.prod and fill in ALL values
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# DATABASE (Primary - Blue)
# ═══════════════════════════════════════════════════════════════
POSTGRES_USER=gloss_prod
POSTGRES_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD_MIN_32_CHARS
POSTGRES_DB=gloss_production

# ═══════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════
REDIS_PASSWORD=CHANGE_ME_PROD_REDIS_PASSWORD_MIN_32_CHARS

# ═══════════════════════════════════════════════════════════════
# MINIO / S3
# ═══════════════════════════════════════════════════════════════
MINIO_ROOT_USER=gloss_minio_prod
MINIO_ROOT_PASSWORD=CHANGE_ME_PROD_MINIO_PASSWORD_MIN_32_CHARS
MINIO_BUCKET=gloss-production-uploads

# ═══════════════════════════════════════════════════════════════
# JWT & AUTH (PRODUCTION - USE STRONG SECRETS!)
# ═══════════════════════════════════════════════════════════════
JWT_ACCESS_SECRET=CHANGE_ME_PROD_ACCESS_SECRET_MIN_64_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_PROD_REFRESH_SECRET_MIN_64_CHARS_RANDOM
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ═══════════════════════════════════════════════════════════════
# YANDEX MAPS (Production API Keys)
# ═══════════════════════════════════════════════════════════════
YANDEX_MAPKIT_API_KEY=PROD_YANDEX_API_KEY

# ═══════════════════════════════════════════════════════════════
# FIREBASE / FCM (Production Project)
# ═══════════════════════════════════════════════════════════════
FCM_SERVER_KEY=PROD_FCM_SERVER_KEY
FCM_PROJECT_ID=gloss-prod-xxx

# ═══════════════════════════════════════════════════════════════
# PAYMENTS - CLICK (Production Credentials)
# ═══════════════════════════════════════════════════════════════
CLICK_MERCHANT_ID=PROD_CLICK_MERCHANT_ID
CLICK_SECRET_KEY=PROD_CLICK_SECRET_KEY
CLICK_SERVICE_ID=PROD_CLICK_SERVICE_ID

# ═══════════════════════════════════════════════════════════════
# PAYMENTS - PAYME (Production Credentials)
# ═══════════════════════════════════════════════════════════════
PAYME_MERCHANT_ID=PROD_PAYME_MERCHANT_ID
PAYME_SECRET_KEY=PROD_PAYME_SECRET_KEY
PAYME_TEST_MODE=false

# ═══════════════════════════════════════════════════════════════
# SMS PROVIDER (Eskiz - Production)
# ═══════════════════════════════════════════════════════════════
SMS_PROVIDER=eskiz
SMS_API_KEY=PROD_ESKIZ_API_KEY
SMS_SENDER_ID=GLOSS

# ═══════════════════════════════════════════════════════════════
# BACKEND CONFIG
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
API_PORT=3000
CORS_ORIGINS=https://gloss.uz,https://client.gloss.uz,https://provider.gloss.uz,https://seller.gloss.uz
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# FRONTEND URLS (Production)
# ═══════════════════════════════════════════════════════════════
CLIENT_APP_URL=https://client.gloss.uz
PROVIDER_APP_URL=https://provider.gloss.uz
SELLER_APP_URL=https://seller.gloss.uz
ADMIN_APP_URL=https://admin.gloss.uz

# ═══════════════════════════════════════════════════════════════
# SENTRY (Production DSN)
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN=https://PROD_SENTRY_DSN@sentry.io/PROJECT_ID

# ═══════════════════════════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════════════════════════
PROMETHEUS_RETENTION=30d
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS (Production)
# ═══════════════════════════════════════════════════════════════
FEATURE_FLAG_NEW_CHECKOUT=true
FEATURE_FLAG_CHAT_V2=true
FEATURE_FLAG_ANALYTICS_V2=true
FEATURE_FLAG_BLUE_GREEN=true